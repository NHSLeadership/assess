{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits"],
  "baseBranches": ["main"],
  "timezone": "Europe/London",
  "schedule": ["* 9-16 * * 1-5"],
  "rangeStrategy": "bump",
  "composerIgnorePlatformReqs": [],
  "dependencyDashboard": true,
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "minimumReleaseAge": "0 days",
    "automerge": true,
    "automergeType": "pr",
    "platformAutomerge": true,
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "matchDepTypes": ["engines"],
      "enabled": false
    },
    {
      "matchManagers": ["composer"],
      "matchDepTypes": ["platform"],
      "enabled": false
    },
    {
      "matchManagers": ["composer"],
      "matchUpdateTypes": ["patch"],
      "groupName": "composer patch updates",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "minimumReleaseAge": "3 days"
    },
    {
      "matchManagers": ["composer"],
      "matchUpdateTypes": ["minor"],
      "groupName": "composer minor updates",
      "automerge": false
    },
    {
      "matchManagers": ["composer"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": true
    },
    {
      "matchManagers": ["composer"],
      "matchPackageNames": ["laravel/framework"],
      "matchUpdateTypes": ["patch"],
      "groupName": "laravel framework patches",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "minimumReleaseAge": "3 days"
    },
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "groupName": "npm patch updates",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "minimumReleaseAge": "3 days"
    },
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor"],
      "groupName": "npm minor updates",
      "automerge": false
    },
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": true
    }
  ]
}