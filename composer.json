{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "nhsleadership/assess",
    "description": "NHS Leadership assessment application",
    "type": "project",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "~8.4",
        "ext-fileinfo": "*",
        "auth0/login": "^7.22",
        "barryvdh/laravel-dompdf": "^3.1.2",
        "diglactic/laravel-breadcrumbs": "^10.1",
        "filament/filament": "^5.6.7",
        "filament/spatie-laravel-settings-plugin": "^5.6.7",
        "flowframe/laravel-trend": "^0.5",
        "jeffersongoncalves/filament-umami": "3.x-dev",
        "laravel/framework": "^13.16.1",
        "laravel/pennant": "^1.23.0",
        "laravel/tinker": "^3.0.2",
        "livewire/volt": "^1.10.5",
        "openplain/filament-tree-view": "^0.5.6",
        "owen-it/laravel-auditing": "^14.0.5",
        "spatie/laravel-prometheus": "^1.6.0",
        "symfony/yaml": "^8.1.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.5.0",
        "fakerphp/faker": "^1.24.1",
        "fruitcake/laravel-debugbar": "^4.3",
        "larastan/larastan": "^3.10.0",
        "laravel/pail": "^1.2.7",
        "laravel/pint": "^1.29.3",
        "laravel/sail": "^1.62.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "pestphp/pest": "^4.7.3",
        "pestphp/pest-plugin-laravel": "^4.1.0",
        "rector/rector": "^2.5.1"
    },
  "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "check-style": "phpcs -p --standard=PSR2 --runtime-set ignore_errors_on_exit 1 --runtime-set ignore_warnings_on_exit 1 app",
        "fix-style": "phpcbf -p --standard=PSR2 --runtime-set ignore_errors_on_exit 1 --runtime-set ignore_warnings_on_exit 1 app",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan vendor:publish --force --tag=livewire:assets --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],


        "check:types": [
            "phpstan analyse --memory-limit=2G"
        ],
        "check:style": [
            "pint --parallel --test"
        ],
        "check:refactor": [
            "rector process --dry-run"
        ],
        "check:all": [
            "@php artisan config:clear --ansi",
            "@check:types",
            "@check:style",
            "@check:refactor"
        ],

        "fix:style": [
            "pint --parallel"
        ],
        "fix:refactor": [
            "rector process"
        ],
        "fix:all": [
            "@fix:style",
            "@fix:refactor",
            "@fix:style"
        ],

        "test:run": [
            "pest --parallel"
        ],
        "test:coverage": [
            "pest --parallel --coverage --min=1%"
        ],

        "test": [
            "@php artisan config:clear --ansi",
            "@test:run"
        ],
        "ci": [
            "@check:all",
            "@test:coverage"
        ]

    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
